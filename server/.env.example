# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=

# JWT
JWT_SECRET=
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRE=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Super Admin Seed
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
