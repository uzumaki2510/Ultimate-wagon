# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://admin:admin@cluster0.xxxxx.mongodb.net/wagon-whisper?retryWrites=true&w=majority

# JWT
JWT_SECRET=wagon-whisper-dev-jwt-secret-2026
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=wagon-whisper-dev-refresh-secret-2026
JWT_REFRESH_EXPIRE=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
